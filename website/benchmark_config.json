  "metric_info": {
    "avg_step_time": {
      "required_update": false,
      "label": "Step Time (s)",
      "description": "Average per-engine-iteration wall time. For vLLM inference (continuous batching), most iterations are decode steps so this is dominated by decode latency. For training, measures the full forward + backward pass. Serving traces (TPOT/TTFT) are reported separately.",
      "higher_is_better": false,
      "unit": "s",
      "category": "model_execution",
      "trace_types": [
        "json_tpu",
        "json"
      ],
      "thresholds": {
        "high": 10,
        "mid": 5
      }
    },
    "ttft": {
      "required_update": false,
      "label": "TTFT (s)",
      "description": "Trace-derived time to first token: duration of the first inference forward/engine execution pass. Only inference workloads report this metric.",
      "higher_is_better": false,
      "unit": "s",
      "category": "model_execution",
      "phases": [
        "inference"
      ],
      "trace_types": [
        "json_tpu",
        "json"
      ],
      "thresholds": {
        "high": 1,
        "mid": 0.2
      }
    },
