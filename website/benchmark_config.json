  "metric_info": {
    "mfu": {
      "label": "MFU (%)",
      "description": "Model FLOPs Utilization — percentage of peak hardware FLOPs utilized during active compute windows",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 25 }
    },
    "avg_step_time": {
      "label": "Step Time (s)",
      "description": "Average step time (inference: decode, training: forward + backward)",
      "higher_is_better": false,
      "unit": "s",
      "thresholds": { "high": 10, "mid": 5 }
    },

    "dominant_kernel_concentration": {
      "label": "Top Kernel (%)",
      "description": "Percentage of total GPU time spent in the single most time-consuming kernel",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 70, "mid": 40 }
    },
    "mean_sm_coverage": {
      "label": "SM Coverage (%)",
      "description": "Average Streaming Multiprocessor coverage across all kernels",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 80, "mid": 50 }
    },
    "memory_bound_fraction": {
      "label": "Mem Bound (%)",
      "description": "Fraction of kernels classified as memory-bound (SM coverage < 50%)",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 60, "mid": 30 }
    },
    "average_memory_bandwidth": {
      "label": "Avg Mem BW (GB/s)",
      "description": "Average memory copy bandwidth across all memcpy operations",
      "higher_is_better": true,
      "unit": "GB/s",
      "thresholds": { "high": 1000, "mid": 500 }
    },
    "communication_ratio": {
      "label": "Comm Ratio (%)",
      "description": "Percentage of total kernel time spent in communication kernels (NCCL, cross-device)",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 20 }
    },
    "memory_transfer_overhead": {
      "label": "Mem Transfer OH (%)",
      "description": "Percentage of trace time spent on memory transfers (memcpy)",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 20, "mid": 5 }
    },
    "aggregate_gpu_utilization": {
      "label": "GPU Util (%)",
      "description": "Overall GPU utilization — merged active kernel time as percentage of trace duration",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 80, "mid": 50 }
    },
    "load_imbalance_ratio": {
      "label": "Load Imbalance",
      "description": "Ratio of max to min GPU active time across GPUs (1.0 = perfectly balanced)",
      "higher_is_better": false,
      "unit": "ratio",
      "thresholds": { "high": 1.5, "mid": 1.2 }
    },
    "communication_overlap_ratio": {
      "label": "Comm Overlap",
      "description": "Fraction of communication time overlapped (hidden) by concurrent computation",
      "higher_is_better": true,
      "unit": "ratio",
      "thresholds": { "high": 0.7, "mid": 0.3 }
    },
    "communication_fraction": {
      "label": "Comm Fraction (%)",
      "description": "Percentage of GPU time in communication kernels (NCCL, cross-device, P2P)",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 20 }
    },
    "moe_fraction": {
      "label": "MoE Fraction (%)",
      "description": "Percentage of GPU time in Mixture of Experts kernels (expert compute, routing, gating, pplx dispatch/combine)",
      "higher_is_better": false,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 20 }
    },
    "compute_bound_fraction": {
      "label": "Compute Bound (%)",
      "description": "Percentage of time in compute-bound kernels (SM coverage > 70%, duration > 10us)",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 60, "mid": 30 }
    },
    "total_kernel_time": {
      "label": "Kernel Time (ms)",
      "description": "Total GPU kernel execution time summed across all kernels",
      "higher_is_better": false,
      "unit": "ms",
      "thresholds": { "high": 10000, "mid": 1000 }
    },
    "total_communication_time": {
      "label": "Comm Time (ms)",
      "description": "Total time in communication kernels (NCCL, cross-device)",
      "higher_is_better": false,
      "unit": "ms",
      "thresholds": { "high": 5000, "mid": 500 }
    },

    "ttft_group_6": {
      "label": "TTFT (ms)",
      "description": "Median time to first token",
      "higher_is_better": false,
      "unit": "ms",
      "thresholds": { "high": 500, "mid": 100 }
    },
    "tpot_group_6": {
      "label": "TPOT (ms)",
      "description": "Median time per output token",
      "higher_is_better": false,
      "unit": "ms",
      "thresholds": { "high": 50, "mid": 20 }
    },
    "throughput_group_6": {
      "label": "Throughput (tok/s)",
      "description": "Output tokens generated per second",
      "higher_is_better": true,
      "unit": "tok/s",
      "thresholds": { "high": 1000, "mid": 200 }
    },
    "kernel_compute_time_group_6": {
      "label": "Kernel Time (s)",
      "description": "Total GPU kernel compute time",
      "higher_is_better": false,
      "unit": "s",
      "thresholds": { "high": 60, "mid": 10 }
    },
    "bandwidth_utilization_allgather_group_6": {
      "label": "AllGather BW (GB/s)",
      "description": "Median effective bandwidth utilization for AllGather operations",
      "higher_is_better": true,
      "unit": "GB/s",
      "thresholds": { "high": 200, "mid": 50 }
    },
    "bandwidth_utilization_allreduce_group_6": {
      "label": "AllReduce BW",
      "description": "Median bandwidth utilization for AllReduce operations",
      "higher_is_better": true,
      "unit": "ratio",
      "thresholds": { "high": 0.5, "mid": 0.1 }
    },
    "bandwidth_utilization_alltoall_group_6": {
      "label": "AllToAll BW (%)",
      "description": "Average NVLink TX throughput utilization during AllToAll operations",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 20 }
    },
    "bandwidth_utilization_peertopeer_group_6": {
      "label": "P2P BW (%)",
      "description": "Average NVLink/PCIe TX throughput utilization during peer-to-peer (pipeline parallelism) operations",
      "higher_is_better": true,
      "unit": "%",
      "thresholds": { "high": 50, "mid": 20 }
    }
  }
}
