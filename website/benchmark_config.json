  "metric_categories": [
    {
      "id": "model_execution",
      "label": "Model Execution",
      "description": "High-level model throughput and latency metrics"
    },
    {
      "id": "gpu_efficiency",
      "label": "GPU Efficiency",
      "description": "GPU utilization, SM coverage, kernel mix, and load balance"
    },
    {
      "id": "memory",
      "label": "Memory",
      "description": "Memory bandwidth and transfer overhead"
    },
    {
      "id": "communication",
      "label": "Communication",
      "description": "Collective communication performance, overlap, and bandwidth"
    }
  ],
  "metric_info": {
    "avg_step_time": {
      "label": "Step Time (s)",
      "description": "Average step time (inference: decode, training: forward + backward). Serving traces is not reported",
      "higher_is_better": false,
      "unit": "s",
      "category": "model_execution",
      "trace_types": [
        "json_tpu",
        "json"
      ],
      "thresholds": {
        "high": 10,
        "mid": 5
      },
      "required_update": false
    },
    "mfu": {
      "label": "MFU (%)",
      "description": "Model FLOPs Utilization \u2014 percentage of peak hardware FLOPs utilized during active compute windows",
      "higher_is_better": true,
      "unit": "%",
      "category": "model_execution",
      "trace_types": [
        "json_tpu",
        "json"
      ],
      "thresholds": {
        "high": 50,
        "mid": 25
      },
      "required_update": false
    },
    "ttft_group_6": {
      "label": "TTFT (ms)",
      "description": "Median time to first token",
      "higher_is_better": false,
      "unit": "ms",
      "category": "model_execution",
      "trace_types": [
        "sglang"
      ],
      "thresholds": {
        "high": 500,
        "mid": 100
      },
      "required_update": false
    },
    "tpot_group_6": {
      "label": "TPOT (ms)",
      "description": "Median time per output token",
      "higher_is_better": false,
      "unit": "ms",
      "category": "model_execution",
      "trace_types": [
        "sglang"
      ],
      "thresholds": {
        "high": 50,
        "mid": 20
      },
      "required_update": false
    },
    "throughput_group_6": {
      "label": "Throughput (tok/s)",
      "description": "Output tokens generated per second",
      "higher_is_better": true,
      "unit": "tok/s",
      "category": "model_execution",
      "trace_types": [
        "sglang"
      ],
      "thresholds": {
        "high": 1000,
        "mid": 200
      },
      "required_update": false
    },
    "mean_sm_coverage": {
      "label": "SM Coverage (%)",
      "description": "Average Streaming Multiprocessor coverage across all kernels",
      "higher_is_better": true,
      "unit": "%",
      "category": "gpu_efficiency",
      "trace_types": [
        "nsys",
        "json"
      ],
      "thresholds": {
        "high": 80,
        "mid": 50
      },
      "required_update": false
    },
    "dominant_kernel_concentration": {
      "label": "Top Kernel (%)",
      "description": "Percentage of total GPU/TPU time spent in the single most time-consuming kernel (GPU) or HLO category (TPU)",
      "higher_is_better": false,
      "unit": "%",
      "category": "gpu_efficiency",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 70,
        "mid": 40
      },
      "required_update": false
    },
    "memory_bound_fraction": {
      "label": "Mem Bound (%)",
      "description": "Fraction of kernel time classified as memory-bound. Uses SM coverage for NSYS traces and kernel-category heuristics for Kineto JSON traces",
      "higher_is_better": false,
      "unit": "%",
      "category": "gpu_efficiency",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 60,
        "mid": 30
      },
      "required_update": false
    },
    "moe_fraction": {
      "label": "MoE Fraction (%)",
      "description": "Percentage of GPU time in Mixture of Experts kernels (expert compute, routing, gating, pplx dispatch/combine)",
      "higher_is_better": false,
      "unit": "%",
      "category": "gpu_efficiency",
      "trace_types": [
        "nsys",
        "json"
      ],
      "thresholds": {
        "high": 50,
        "mid": 20
      },
      "required_update": false
    },
    "average_memory_bandwidth": {
      "label": "Avg Mem BW (GB/s)",
      "description": "Average memory copy bandwidth. GPU: total bytes / total memcpy duration from CUPTI or Kineto. TPU: total bytes / elapsed time between XLA copy-start and copy-done events (conservative lower bound, includes scheduling overhead)",
      "higher_is_better": true,
      "unit": "GB/s",
      "category": "memory",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 1000,
        "mid": 500
      },
      "required_update": false
    },
    "memory_transfer_overhead": {
      "label": "Mem Transfer OH (%)",
      "description": "Percentage of trace time spent on memory transfers (memcpy for NSYS, copy-like kernels for Kineto JSON)",
      "higher_is_better": false,
      "unit": "%",
      "category": "memory",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 20,
        "mid": 5
      },
      "required_update": false
    },
    "communication_fraction": {
      "label": "Comm Fraction (%)",
      "description": "Percentage of GPU/TPU time in communication kernels (NCCL, cross-device, P2P, XLA collectives)",
      "higher_is_better": false,
      "unit": "%",
      "category": "communication",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 50,
        "mid": 20
      },
      "required_update": false
    },
    "total_communication_time": {
      "label": "Comm Time (s)",
      "description": "Total exposed time in communication kernels (NCCL, cross-device, XLA collectives). We don't double-count overlapped portion.",
      "higher_is_better": false,
      "unit": "s",
      "category": "communication",
      "trace_types": [
        "nsys",
        "json",
        "json_tpu"
      ],
      "thresholds": {
        "high": 5,
        "mid": 0.5
      },
      "required_update": false
    },
    "bandwidth_utilization_allgather_group_6": {
      "label": "AllGather BW (GB/s)",
      "description": "Median effective bandwidth utilization for AllGather operations",
      "higher_is_better": true,
      "unit": "GB/s",
      "category": "communication",
      "trace_types": [
        "json"
      ],
      "thresholds": {
        "high": 200,
